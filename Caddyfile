{
    local_certs
}

localhost {
    # Keycloak is not proxied by default, accessed directly if needed.

    # Spring Boot Admin
    handle_path /admin/* {
        reverse_proxy admin:8080
    }

    # Backend API
    handle_path /api/* {
        reverse_proxy backend:8080
    }

    # Frontend App
    handle {
        reverse_proxy frontend:3000
    }
}
